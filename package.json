{
  "name": "unplugin-derive",
  "version": "0.3.1",
  "description": "Generate derived artifacts from your project files with a flexible, unplugin-based abstraction.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      },
      "default": "./dist/vite.js"
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.ts",
        "default": "./dist/rollup.js"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      },
      "default": "./dist/rollup.js"
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      },
      "default": "./dist/webpack.js"
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.ts",
        "default": "./dist/esbuild.js"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      },
      "default": "./dist/esbuild.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "micromatch": "^4.0.8",
    "unplugin": "^2.3.5"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "keywords": [],
  "author": "Xu Yiming",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xuyimingwork/unplugin-derive.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
